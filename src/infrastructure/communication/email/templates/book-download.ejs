<!DOCTYPE html>
<html lang="en" style="margin:0;padding:0;">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Book Purchase Successful</title>
  </head>
  <body style="margin:0;padding:0;background:#f6f8f4;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f6f8f4;">
      <tr>
        <td align="center" style="padding:28px 14px;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="640" style="width:640px;max-width:100%;background:#ffffff;border:1px solid #e2eadf;border-radius:14px;overflow:hidden;">
            <tr>
              <td style="background:#10194a;padding:22px 26px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td>
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td style="padding-right:10px;vertical-align:middle;"><img src="https://tai-backend-v1.onrender.com/images/logo.png" alt="The Agudah Institute" width="42" height="42" style="display:block;border:0;border-radius:8px;" /></td>
                          <td style="font-family:Arial,Helvetica,sans-serif;color:#ffffff;font-size:17px;font-weight:700;vertical-align:middle;">The Agudah Institute</td>
                        </tr>
                      </table>
                    </td>
                    <td align="right" style="font-family:Arial,Helvetica,sans-serif;color:#c8f7d0;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Book Purchase</td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:34px 30px 10px 30px;">
                <p style="margin:0 0 8px 0;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.7;color:#58606b;">Hello <strong style="color:#10194a;"><%= username || "Reader" %></strong>,</p>
                <h1 style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:25px;line-height:1.25;color:#10194a;font-weight:800;">Your book is ready</h1>
                <p style="margin:12px 0 0 0;font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.7;color:#384152;">Your purchase was successful. You can now access the book from your library.</p>
              </td>
            </tr>

            <tr>
              <td style="padding:22px 30px 8px 30px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#fbfcfa;border:1px solid #e8eee5;border-radius:12px;">
                  <tr>
                    <td style="padding:20px 20px 12px 20px;font-family:Arial,Helvetica,sans-serif;font-size:18px;line-height:1.35;color:#10194a;font-weight:800;"><%= book_title %></td>
                  </tr>
                  <tr>
                    <td style="padding:0 20px 20px 20px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                        <tr>
                          <td width="42%" style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Author</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= book_author || "N/A" %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Price</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= (price && Number(price) > 0) ? ("₦" + Number(price).toLocaleString()) : "Free" %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Transaction</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= transaction_ref || "N/A" %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Purchased</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= purchased_at || "N/A" %></td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:18px 30px 34px 30px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="background:#55d368;border-radius:8px;">
                      <a href="<%= library_url %>" target="_blank" rel="noopener noreferrer" style="display:inline-block;padding:13px 20px;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:800;color:#10194a;text-decoration:none;">Open My Library</a>
                    </td>
                  </tr>
                </table>
                <p style="margin:14px 0 0 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:1.7;color:#596273;">If you have any issue accessing your book, contact support and share your transaction reference.</p>
              </td>
            </tr>

            <tr>
              <td style="background:#eefbf0;padding:18px 26px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#34405f;">Need help? <a href="mailto:hello@theagudahinstitute.com" style="color:#10194a;text-decoration:underline;">hello@theagudahinstitute.com</a></td>
                    <td align="right" style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#34405f;">© <%= new Date().getFullYear() %> The Agudah Institute</td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
