<!DOCTYPE html>
<html lang="en" style="margin:0;padding:0;">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Your Verification Code</title>
  </head>
  <body style="margin:0;padding:0;background:#f6f8f4;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f6f8f4;">
      <tr>
        <td align="center" style="padding:28px 14px;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="640" style="width:640px;max-width:100%;background:#ffffff;border:1px solid #e2eadf;border-radius:14px;overflow:hidden;">
            <tr>
              <td style="background:#10194a;padding:22px 26px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                  <tr>
                    <td>
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td style="padding-right:10px;vertical-align:middle;">
                            <img src="https://tai-backend-v1.onrender.com/images/logo.png" alt="The Agudah Institute" width="42" height="42" style="display:block;border:0;border-radius:8px;" />
                          </td>
                          <td style="font-family:Arial,Helvetica,sans-serif;color:#ffffff;font-size:17px;font-weight:700;vertical-align:middle;">
                            The Agudah Institute
                          </td>
                        </tr>
                      </table>
                    </td>
                    <td align="right" style="font-family:Arial,Helvetica,sans-serif;color:#c8f7d0;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">
                      Verification Code
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:34px 30px 10px 30px;">
                <p style="margin:0 0 8px 0;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.7;color:#58606b;">Hello <strong style="color:#10194a;"><%= first_name || "Member" %></strong>,</p>
                <h1 style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:25px;line-height:1.25;color:#10194a;font-weight:800;">Confirm your account</h1>
                <p style="margin:12px 0 0 0;font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.7;color:#384152;">Use this one-time code to verify your TAI account and complete your setup.</p>
              </td>
            </tr>

            <tr>
              <td align="center" style="padding:22px 30px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="background:#eefbf0;border:1px solid #b9e8c0;border-radius:12px;">
                  <tr>
                    <td align="center" style="padding:20px 30px;">
                      <div style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#657063;font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px;">Your code</div>
                      <div style="font-family:Arial,Helvetica,sans-serif;font-size:32px;line-height:1;color:#10194a;font-weight:800;letter-spacing:6px;"><%= otp %></div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:0 30px 34px 30px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#fbfcfa;border:1px solid #e8eee5;border-radius:10px;">
                  <tr>
                    <td style="padding:14px 16px;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:1.65;color:#596273;">
                      This code expires in <strong style="color:#10194a;"><%= "3 minutes" %></strong>. If you did not request this, you can safely ignore this email.
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="background:#eefbf0;padding:18px 26px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#34405f;">
                      Need help? <a href="mailto:hello@theagudahinstitute.com" style="color:#10194a;text-decoration:underline;">hello@theagudahinstitute.com</a>
                    </td>
                    <td align="right" style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#34405f;">
                      © <%= new Date().getFullYear() %> The Agudah Institute
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
