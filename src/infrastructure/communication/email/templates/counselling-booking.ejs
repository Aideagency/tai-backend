<!DOCTYPE html>
<html lang="en" style="margin:0;padding:0;">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Counselling Booking Confirmation</title>
  </head>
  <body style="margin:0;padding:0;background:#f6f8f4;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f6f8f4;">
      <tr>
        <td align="center" style="padding:28px 14px;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="640" style="width:640px;max-width:100%;background:#ffffff;border:1px solid #e2eadf;border-radius:14px;overflow:hidden;">
            <tr>
              <td style="background:#10194a;padding:22px 26px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td>
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td style="padding-right:10px;vertical-align:middle;">
                            <img src="https://tai-backend-v1.onrender.com/images/logo.png" alt="The Agudah Institute" width="42" height="42" style="display:block;border:0;border-radius:8px;" />
                          </td>
                          <td style="font-family:Arial,Helvetica,sans-serif;color:#ffffff;font-size:17px;font-weight:700;vertical-align:middle;">The Agudah Institute</td>
                        </tr>
                      </table>
                    </td>
                    <td align="right" style="font-family:Arial,Helvetica,sans-serif;color:#c8f7d0;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Counselling Booking</td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:34px 30px 10px 30px;">
                <p style="margin:0 0 8px 0;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.7;color:#58606b;">Hello <strong style="color:#10194a;"><%= username || "Client" %></strong>,</p>
                <h1 style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:25px;line-height:1.25;color:#10194a;font-weight:800;">Your session is confirmed</h1>
                <p style="margin:12px 0 0 0;font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.7;color:#384152;">Your counselling booking has been confirmed. The session details are below.</p>
              </td>
            </tr>

            <tr>
              <td style="padding:22px 30px 8px 30px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#fbfcfa;border:1px solid #e8eee5;border-radius:12px;">
                  <tr>
                    <td style="padding:20px 20px 8px 20px;font-family:Arial,Helvetica,sans-serif;font-size:18px;line-height:1.35;color:#10194a;font-weight:800;"><%= counselling_title %></td>
                  </tr>
                  <tr>
                    <td style="padding:0 20px 20px 20px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                        <tr>
                          <td width="42%" style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Booking reference</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= booking_reference %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Status</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= booking_status %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Mode</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= counselling_mode %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Location</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= location_text || "N/A" %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Meeting link</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;">
                            <% if (meeting_link) { %>
                              <a href="<%= meeting_link %>" style="color:#10194a;text-decoration:underline;">Join Session</a>
                            <% } else { %>
                              N/A
                            <% } %>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Price</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= price > 0 ? ("₦" + price) : "Free" %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Starts</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= start_date %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Ends</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= end_date %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Duration</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= duration_minutes %> minutes</td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Counsellor</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= counsellor_name || "Not Assigned" %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Attendance</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= attended ? "Yes" : "No" %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Transaction</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= transaction_ref || "N/A" %></td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <% if (client_notes || counsellor_notes) { %>
            <tr>
              <td style="padding:12px 30px 8px 30px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#eefbf0;border:1px solid #b9e8c0;border-radius:12px;">
                  <% if (client_notes) { %>
                  <tr>
                    <td style="padding:16px 18px 4px 18px;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#657063;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Your notes</td>
                  </tr>
                  <tr>
                    <td style="padding:0 18px 14px 18px;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.65;color:#293241;"><%= client_notes %></td>
                  </tr>
                  <% } %>
                  <% if (counsellor_notes) { %>
                  <tr>
                    <td style="padding:16px 18px 4px 18px;border-top:1px solid #d8efd8;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#657063;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Counsellor notes</td>
                  </tr>
                  <tr>
                    <td style="padding:0 18px 16px 18px;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.65;color:#293241;"><%= counsellor_notes %></td>
                  </tr>
                  <% } %>
                </table>
              </td>
            </tr>
            <% } %>

            <tr>
              <td style="padding:14px 30px 34px 30px;">
                <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:1.7;color:#596273;">Please keep this email for your records. If anything changes, contact support with your booking reference.</p>
              </td>
            </tr>

            <tr>
              <td style="background:#eefbf0;padding:18px 26px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#34405f;">Need help? <a href="mailto:hello@theagudahinstitute.com" style="color:#10194a;text-decoration:underline;">hello@theagudahinstitute.com</a></td>
                    <td align="right" style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#34405f;">© <%= new Date().getFullYear() %> The Agudah Institute</td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
