<!DOCTYPE html>
<html lang="en" style="margin:0;padding:0;">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Course Enrollment Successful</title>
  </head>
  <body style="margin:0;padding:0;background:#f6f8f4;">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#f6f8f4;">
      <tr>
        <td align="center" style="padding:28px 14px;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="640" style="width:640px;max-width:100%;background:#ffffff;border:1px solid #e2eadf;border-radius:14px;overflow:hidden;">
            <tr>
              <td style="background:#10194a;padding:22px 26px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td>
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td style="padding-right:10px;vertical-align:middle;"><img src="https://tai-backend-v1.onrender.com/images/logo.png" alt="The Agudah Institute" width="42" height="42" style="display:block;border:0;border-radius:8px;" /></td>
                          <td style="font-family:Arial,Helvetica,sans-serif;color:#ffffff;font-size:17px;font-weight:700;vertical-align:middle;">The Agudah Institute</td>
                        </tr>
                      </table>
                    </td>
                    <td align="right" style="font-family:Arial,Helvetica,sans-serif;color:#c8f7d0;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;">Course Enrollment</td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:34px 30px 10px 30px;">
                <p style="margin:0 0 8px 0;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.7;color:#58606b;">Hello <strong style="color:#10194a;"><%= username || "Student" %></strong>,</p>
                <h1 style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:25px;line-height:1.25;color:#10194a;font-weight:800;">Your course is unlocked</h1>
                <p style="margin:12px 0 0 0;font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.7;color:#384152;">
                  <%= isPaid ? "Your payment was successful, and you have been enrolled in the course below." : "You have been successfully enrolled in the course below." %>
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:22px 30px 34px 30px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background:#fbfcfa;border:1px solid #e8eee5;border-radius:12px;">
                  <tr>
                    <td style="padding:20px 20px 8px 20px;font-family:Arial,Helvetica,sans-serif;font-size:18px;line-height:1.35;color:#10194a;font-weight:800;"><%= course_title %></td>
                  </tr>
                  <% if (course_description) { %>
                  <tr>
                    <td style="padding:0 20px 14px 20px;font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.65;color:#596273;"><%= course_description %></td>
                  </tr>
                  <% } %>
                  <tr>
                    <td style="padding:0 20px 20px 20px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                        <tr>
                          <td width="42%" style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Access type</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= access_kind %></td>
                        </tr>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Price</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= price > 0 ? ("₦" + price) : "Free" %></td>
                        </tr>
                        <% if (starts_at) { %>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Access starts</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= starts_at %></td>
                        </tr>
                        <% } %>
                        <% if (ends_at) { %>
                        <tr>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#788172;text-transform:uppercase;letter-spacing:.5px;">Access ends</td>
                          <td style="padding:9px 0;border-top:1px solid #edf1ea;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#293241;font-weight:700;"><%= ends_at %></td>
                        </tr>
                        <% } %>
                      </table>
                    </td>
                  </tr>
                </table>
                <p style="margin:14px 0 0 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:1.7;color:#596273;">You can now access this course from your dashboard and learn at your own pace.</p>
              </td>
            </tr>

            <tr>
              <td style="background:#eefbf0;padding:18px 26px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#34405f;">Need help? <a href="mailto:hello@theagudahinstitute.com" style="color:#10194a;text-decoration:underline;">hello@theagudahinstitute.com</a></td>
                    <td align="right" style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#34405f;">© <%= new Date().getFullYear() %> The Agudah Institute</td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
