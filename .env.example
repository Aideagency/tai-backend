# App
NODE_ENV=development
PORT=3000
SESSION_SECRET=replace-with-a-long-random-session-secret

# Database
# Example: postgres://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tai
# Use false for local Postgres. Use true for Supabase or other hosted Postgres that requires SSL.
DATABASE_SSL=false

# User JWT auth
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=1d

# Admin JWT auth
ADMIN_JWT_SECRET=replace-with-a-long-random-admin-jwt-secret
ADMIN_JWT_EXPIRES_IN=30m

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-or-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Paystack
PAYSTACK_KEY=sk_test_your-paystack-secret-key

# Email - Resend is used by the current EmailService send path
RESEND_KEY=re_your-resend-api-key

# Email - SMTP fallback
MAIL_SERVICE=gmail
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password

# Email - SendGrid client
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Bible API
BIBLE_KEY=your-bible-api-key
BIBLE_ID=your-bible-id

# Zoho Learn
ZOHO_REGION=com
ZOHO_LEARN_PORTAL=your-zoho-learn-portal
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
