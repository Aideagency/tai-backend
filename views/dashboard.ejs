<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    :root {
      --color-primary: #55D368;
      --color-primary-light: #6FE886;
      --color-primary-dark: #2FA748;

      --color-secondary: #8EE29A;
      --color-secondary-light: #A8F7B3;
      --color-secondary-dark: #65B171;
    }
  </style>
</head>

<body class="min-h-screen bg-gray-100">
  <%
    const summary = dashboard || { overview: [], modules: [] };
    const formatNumber = (value) => Number(value || 0).toLocaleString();
  %>

  <div class="flex">

    <!-- Sidebar -->
    <%- include('partials/sidebar', { admin, currentPath: "dashboard" }) %>

    <!-- Main content -->
    <div class="flex-1 flex flex-col min-h-screen">

      <!-- Header -->
      <%- include('partials/header', {
        admin,
        pageTitle: 'Dashboard'
      }) %>

      <!-- Page content -->
      <main class="p-6 space-y-6">
        <!-- Top Stats -->
        <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
          <% summary.overview.forEach((stat) => { %>
            <a
              href="<%= stat.href %>"
              class="group bg-white rounded-2xl shadow-sm p-5 border border-[var(--color-primary-light)] hover:border-[var(--color-primary-dark)] hover:shadow-md transition duration-200"
            >
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-gray-500"><%= stat.label %></p>
                  <p class="mt-2 text-3xl font-bold text-[var(--color-primary-dark)]"><%= formatNumber(stat.value) %></p>
                  <p class="mt-2 text-xs text-gray-500"><%= stat.helper %></p>
                </div>
                <span class="rounded-full bg-green-50 px-2.5 py-1 text-xs font-semibold text-[var(--color-primary-dark)] group-hover:bg-[var(--color-primary)] group-hover:text-white">
                  View
                </span>
              </div>
            </a>
          <% }) %>
        </section>

        <!-- Module Snapshot -->
        <section class="space-y-4">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-base font-semibold text-gray-900">Module Snapshot</h3>
              <p class="mt-1 text-sm text-gray-500">Jump straight into the module that needs attention.</p>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-4 lg:grid-cols-2 2xl:grid-cols-3">
            <% summary.modules.forEach((module) => { %>
              <a
                href="<%= module.href %>"
                class="group block rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition duration-200 hover:border-[var(--color-primary)] hover:shadow-md"
              >
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-sm font-semibold text-gray-900"><%= module.title %></p>
                    <div class="mt-3 flex items-end gap-2">
                      <span class="text-3xl font-bold text-gray-900"><%= formatNumber(module.value) %></span>
                      <span class="pb-1 text-xs font-medium text-gray-500"><%= module.label %></span>
                    </div>
                  </div>
                  <span class="rounded-lg border border-[var(--color-primary-light)] px-3 py-1.5 text-xs font-semibold text-[var(--color-primary-dark)] group-hover:bg-[var(--color-primary)] group-hover:text-white">
                    Open
                  </span>
                </div>

                <div class="mt-5 divide-y divide-gray-100 border-t border-gray-100">
                  <% module.details.forEach((detail) => { %>
                    <div class="flex items-center justify-between py-2.5">
                      <span class="text-xs font-medium text-gray-500"><%= detail.label %></span>
                      <span class="text-sm font-semibold text-gray-800"><%= formatNumber(detail.value) %></span>
                    </div>
                  <% }) %>
                </div>
              </a>
            <% }) %>
          </div>
        </section>

      </main>
    </div>

  </div>

</body>
</html>
